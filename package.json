{
  "name": "devaseva-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "user-app",
    "pro-panel",
    "admin-panel/admin"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=@devaseva/core",
    "build:all": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "firebase-tools": "^15.19.1"
  },
  "dependencies": {
    "firebase-admin": "^14.0.0"
  },
  "overrides": {
    "nativewind": {
      "tailwindcss": "~3.4.19"
    },
    "react-native-css-interop": {
      "tailwindcss": "~3.4.19"
    }
  }
}
