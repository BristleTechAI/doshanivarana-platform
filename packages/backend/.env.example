# Agora Credentials — get from console.agora.io
# Required for token generation endpoint (/api/agora/token)
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# Required for Cloud Recording endpoints (/api/agora/recording/*)
# Get from console.agora.io → RESTful API → Customer ID + Secret
AGORA_CUSTOMER_KEY=YOUR_CUSTOMER_KEY
AGORA_CUSTOMER_SECRET=YOUR_CUSTOMER_SECRET

# Cloud Recording Storage (Agora stores to S3/GCS/OSS)
AGORA_STORAGE_BUCKET=YOUR_BUCKET_NAME
AGORA_STORAGE_KEY=YOUR_STORAGE_ACCESS_KEY
AGORA_STORAGE_SECRET=YOUR_STORAGE_SECRET_KEY

# ─── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
# 1. Create OAuth2 Client ID (Desktop or Web app type)
# 2. Enable YouTube Data API v3 in your project
# 3. Get a refresh token using OAuth2 Playground:
#    https://developers.google.com/oauthplayground
#    Scope: https://www.googleapis.com/auth/youtube.upload
YOUTUBE_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
YOUTUBE_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
YOUTUBE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

# Server port
PORT=3001
